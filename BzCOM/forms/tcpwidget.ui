       <property name="styleSheet">
        <string notr="true">/* 统一所有输入框（QLineEdit + QComboBox）的样式 */
QLineEdit, QComboBox {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 16px;
    color: #333333;
}

/* QComboBox 下拉箭头区域样式（避免额外凸起 + 无警告） */
QComboBox::drop-down {
    border: none;
    background-color: transparent;
    width: 20px;
}
QComboBox::down-arrow {
    image: none;
    width: 12px;
    height: 12px;
}

/* 聚焦状态保持一致 */
QLineEdit:focus, QComboBox:focus {
    border: 1px solid #40a9ff;
    outline: none;
}</string>
