       <item>
        <widget class="QPushButton" name="connectBtn">
         <property name="styleSheet">
          <string notr="true">/* QPushButton 基础样式 - 核心暗黑风格 */
QPushButton {
    background-color: #1a1a1a;  /* 深黑色背景 */
    border-radius: 12px;         /* 圆角 */
    border: 2px solid #2d2d2d;  /* 统一边框宽度为2px */

    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 16px;            
    color: #ffffff;              

    padding: 5px 10px;          
    min-width: 80px;            
    min-height: 28px;           
}

/* 鼠标悬停 - 轻微提亮 */
QPushButton:hover {
    background-color: #2a2a2a;
    border-color: #3d3d3d;
}

/* 按下效果 - 加深背景 */
QPushButton:pressed {
    background-color: #0a0a0a;
}

/* 禁用状态 - 灰色调 */
QPushButton:disabled {
    background-color: #2c2c2c;
    color: #666666;
}

/* 连接成功（断开状态）- 红色高亮样式 */
QPushButton[connected=&quot;true&quot;] {
    background-color: #ff0000;    /* 纯红色背景 */
    border: 2px solid #ffffff;    /* 保持边框宽度2px，仅改颜色 */
    color: #ffffff;               /* 白色文字 */
}
QPushButton[connected=&quot;true&quot;]:hover {
    background-color: #ff3333;
}
QPushButton[connected=&quot;true&quot;]:pressed {
    background-color: #cc0000;
}</string>
