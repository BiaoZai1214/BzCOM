         <property name="styleSheet">
          <string notr="true">/* 统一所有输入框（QLineEdit + QComboBox）的样式 */
 QComboBox {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 14px;
    color: #333333;
}

/* 彻底隐藏QComboBox下拉区域：宽度设为0，无任何交互 */
QComboBox::drop-down {
    border: none;
    background-color: transparent;
    width: 0px; /* 关键：将下拉区域宽度设为0，视觉上完全消失 */
}
QComboBox::down-arrow {
    image: none; /* 清空箭头图标，避免资源加载警告 */
    width: 0px;
    height: 0px;
}

/* 可选：QComboBox 编辑区域文字居中（兼容可编辑场景） */
QComboBox QAbstractItemView {
    text-align: center;
    alignment: AlignCenter;
}</string>
